# 百炼大模型 API Key
DASHSCOPE_API_KEY=your-api-key-here

# 服务器配置（可选）
HOST=0.0.0.0
PORT=8000

# 侨批生成器管理员账号密码；管理员可访问 /admin
# 普通用户可在登录页用手机号码或邮箱注册
QIAOPI_USERNAME=admin
QIAOPI_PASSWORD=change-this-password
QIAOPI_SESSION_SECRET=change-this-random-session-secret
QIAOPI_SESSION_MAX_AGE=604800
QIAOPI_DATA_KEY=change-this-random-data-encryption-key
QIAOPI_SHARE_ACCESS_MAX_AGE=604800

# 公网分享地址，部署到云服务器后改成你的公网 IP 或域名
# 示例：http://1.2.3.4:8000
# 示例：https://qiaopi.example.com
PUBLIC_BASE_URL=http://your-public-ip:8000
